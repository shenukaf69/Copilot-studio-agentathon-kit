{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Contract Sent for Signature",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Legal Contract Review Copilot",
      "isSubtle": true,
      "spacing": "None",
      "wrap": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Contract ID:",
          "value": "{{ContractID}}"
        },
        {
          "title": "Signer:",
          "value": "{{SignerName}}"
        },
        {
          "title": "Signer Email:",
          "value": "{{SignerEmail}}"
        },
        {
          "title": "Effective Date:",
          "value": "{{EffectiveDate}}"
        },
        {
          "title": "Envelope ID:",
          "value": "{{EnvelopeID}}"
        }
      ]
    }
  ]
}
{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Audit Finding Raised",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Audit & Reporting Q&A Copilot",
      "isSubtle": true,
      "spacing": "None",
      "wrap": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Journal ID:",
          "value": "{{JournalID}}"
        },
        {
          "title": "Period:",
          "value": "{{Period}}"
        },
        {
          "title": "Finding Category:",
          "value": "{{FindingCategory}}"
        },
        {
          "title": "Auditor Note:",
          "value": "{{AuditorNote}}"
        },
        {
          "title": "Suggested Action:",
          "value": "{{SuggestedAction}}"
        }
      ]
    }
  ]
}
{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Daily Stand-up Posted",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "Store Ops Daily Copilot",
      "isSubtle": true,
      "spacing": "None",
      "wrap": true
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Store:",
          "value": "{{StoreID}}"
        },
        {
          "title": "Date:",
          "value": "{{Date}}"
        },
        {
          "title": "Headline Metric:",
          "value": "{{HeadlineMetric}}"
        },
        {
          "title": "Top Action:",
          "value": "{{TopAction}}"
        }
      ]
    }
  ]
}